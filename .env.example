# Upload keys: clientId:org:secret (comma-separated). Generate a secret: openssl rand -hex 24
# Uncomment and set a REAL secret. Placeholder values (CHANGE_ME /
# REPLACE_WITH_LONG_RANDOM_SECRET) are ignored at startup, so a copied example never leaves
# a known admin key live on /mcp.
# ARTIFACT_API_KEYS=me:admin:REPLACE_WITH_LONG_RANDOM_SECRET

# Encrypt Discord webhook URLs in SQLite with AES-256-GCM. Generate once with:
#   openssl rand -base64 32
# Keep this key with deployment secrets and backups. If unset, webhook URLs still work but are
# stored in plaintext and startup emits a prominent warning. See README.md before rotating it.
# WEBHOOK_ENC_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

# Public base URL used to build artifact/share links (no trailing slash).
# In production set this to your real hostname; defaults to http://localhost:3480.
PUBLIC_BASE_URL=http://localhost:3480

# Host-side port publish. Loopback prevents direct LAN ingress; for fully private tunnel-only
# ingress, remove the app's ports publish and enable the same-network cloudflared service.
HOST_BIND=127.0.0.1

# Optional pretty-name / merge overrides. Default: the email domain IS the org.
# ORG_EMAIL_DOMAINS=example.com:acme,other.com:acme

# Who sees every org (admin)
ADMIN_EMAILS=you@example.com

# Artifact payload caps
MAX_ARTIFACT_BYTES=2097152
MAX_BUNDLE_BYTES=8388608
MAX_BUNDLE_FILES=100
# Retained revisions per artifact / max feedback length (optional; defaults shown)
# MAX_HISTORY=20
# FEEDBACK_MAX_BODY=4000
# Optional request-envelope override; computed from MAX_BUNDLE_BYTES when omitted.
# MCP_JSON_LIMIT=17039360

# Cloudflare Access JWT verification (set both in production once the Access app exists).
# CF_ACCESS_TEAM_DOMAIN=yourteam.cloudflareaccess.com
# CF_ACCESS_AUD=your-access-app-aud-tag
# Local/loopback development only: trust the spoofable Access email header when JWT is unset.
# TRUST_ACCESS_HEADERS=1
# Interface the app binds inside the process. Default 0.0.0.0 (a container needs it). For
# bare-metal dev with TRUST_ACCESS_HEADERS, bind loopback so the spoofable header isn't
# LAN-reachable (`npm run dev` sets this automatically). Header-trust refuses to start on a
# non-loopback bind unless HEADER_TRUST_ALLOW_INSECURE=1 (only when a proxy controls exposure).
# LISTEN_HOST=127.0.0.1
# HEADER_TRUST_ALLOW_INSECURE=1
# Production/CI strict mode: refuse startup unless both JWT settings above are configured.
# REQUIRE_ACCESS_JWT=1
